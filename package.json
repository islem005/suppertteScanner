{
  "name": "supperttescanner",
  "version": "1.0.0",
  "description": "Fast barcode scanner for shelf inventory",
  "private": true,
  "scripts": {
    "dev": "vite --host",
    "dev:backend": "cd api && bunx wrangler dev --port 3002 --remote",
    "dev:all": "concurrently -n fe,api -c cyan,yellow \"bun run dev\" \"bun run dev:backend\"",
    "db:migrate": "cd api && bunx wrangler d1 execute shelf-scanner-dev --local --file=./migrations/001_init.sql",
    "start": "node start.mjs",
    "build": "vite build && node copy-assets.mjs",
    "preview": "vite preview --host",
    "test": "vitest run",
    "test:api": "vitest run --reporter=verbose",
    "test:api:watch": "vitest --reporter=verbose",
    "test:watch": "vitest --reporter=verbose",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "deploy:fe": "node build-frontend.mjs && cd frontend-worker && wrangler deploy",
    "deploy:api": "cd api && wrangler deploy --config wrangler.prod.toml",
    "deploy:all": "node build-frontend.mjs && cd frontend-worker && wrangler deploy && cd ../api && wrangler deploy --config wrangler.prod.toml",
    "lint": "eslint . --ext .js,.html --ignore-pattern dist --ignore-pattern node_modules --ignore-pattern 'frontend-worker/public'",
    "lint:fix": "eslint . --ext .js,.html --fix --ignore-pattern dist --ignore-pattern node_modules --ignore-pattern 'frontend-worker/public'"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@morphllm/opencode-morph-plugin": "^2.0.9",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitest/ui": "^4.1.7",
    "concurrently": "^9.2.1",
    "jsdom": "^29.1.1",
    "vite": "^8.0.14",
    "vitest": "^4.1.7",
    "eslint": "^9.0.0",
    "prettier": "^3.2.0"
  },
  "dependencies": {
    "swiper": "^12.2.0"
  }
}
