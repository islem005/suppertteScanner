{
  "env": {
    "browser": true,
    "es2024": true,
    "node": true,
    "worker": true
  },
  "extends": ["eslint:recommended"],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-console": "off",
    "prefer-const": "warn",
    "no-var": "warn",
    "eqeqeq": "warn"
  },
  "ignorePatterns": ["dist/", "frontend-worker/public/", "node_modules/", "*.min.js"]
}
